{
	"info": {
		"_postman_id": "attendance-api",
		"name": "Attendance API",
		"description": "Complete API collection for Attendance module",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{AUTHORIZATION}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000/api",
			"type": "string"
		},
		{
			"key": "AUTHORIZATION",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.environment.set('AUTHORIZATION', jsonData.token);",
									"    pm.collectionVariables.set('AUTHORIZATION', jsonData.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"employee_id\": \"1\",\n    \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/login",
							"host": ["{{base_url}}"],
							"path": ["login"]
						}
					}
				}
			]
		},
		{
			"name": "Attendance CRUD",
			"item": [
				{
					"name": "List Attendances",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/attendances?per_page=10&page=1",
							"host": ["{{base_url}}"],
							"path": ["attendances"],
							"query": [
								{"key": "per_page", "value": "10"},
								{"key": "page", "value": "1"},
								{"key": "employee_id", "value": "", "disabled": true},
								{"key": "date", "value": "", "disabled": true},
								{"key": "status", "value": "", "disabled": true},
								{"key": "search", "value": "", "disabled": true},
								{"key": "sort", "value": "check_in", "disabled": true},
								{"key": "direction", "value": "desc", "disabled": true}
							]
						}
					}
				},
				{
					"name": "Create Attendance",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"employee_id\": 1,\n    \"date\": \"2024-12-30\",\n    \"check_in\": \"2024-12-30 09:00:00\",\n    \"check_out\": \"2024-12-30 17:00:00\",\n    \"location\": \"Office Building A\",\n    \"notes\": \"Regular work day\",\n    \"status\": \"present\",\n    \"break_duration_minutes\": 60\n}"
						},
						"url": {
							"raw": "{{base_url}}/attendances",
							"host": ["{{base_url}}"],
							"path": ["attendances"]
						}
					}
				},
				{
					"name": "Get Attendance",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/attendances/1",
							"host": ["{{base_url}}"],
							"path": ["attendances", "1"]
						}
					}
				},
				{
					"name": "Update Attendance (Partial)",
					"request": {
						"method": "PUT",
						"header": [
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"status\": \"half_day\",\n    \"notes\": \"Updated notes\",\n    \"break_duration_minutes\": 90\n}"
						},
						"url": {
							"raw": "{{base_url}}/attendances/1",
							"host": ["{{base_url}}"],
							"path": ["attendances", "1"]
						}
					}
				},
				{
					"name": "Delete Attendance",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/attendances/1",
							"host": ["{{base_url}}"],
							"path": ["attendances", "1"]
						}
					}
				}
			]
		},
		{
			"name": "Check-In / Check-Out",
			"item": [
				{
					"name": "Check In",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"location\": \"Office Building A\",\n    \"notes\": \"Starting work day\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/attendance/check-in",
							"host": ["{{base_url}}"],
							"path": ["attendance", "check-in"]
						}
					}
				},
				{
					"name": "Check Out",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"location\": \"Office Building A\",\n    \"notes\": \"Ending work day\",\n    \"break_duration_minutes\": 60\n}"
						},
						"url": {
							"raw": "{{base_url}}/attendance/check-out",
							"host": ["{{base_url}}"],
							"path": ["attendance", "check-out"]
						}
					}
				},
				{
					"name": "Check Out (With Date)",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"date\": \"2024-12-30\",\n    \"location\": \"Office Building A\",\n    \"notes\": \"Ending work day\",\n    \"break_duration_minutes\": 60\n}"
						},
						"url": {
							"raw": "{{base_url}}/attendance/check-out",
							"host": ["{{base_url}}"],
							"path": ["attendance", "check-out"]
						}
					}
				}
			]
		}
	]
}

